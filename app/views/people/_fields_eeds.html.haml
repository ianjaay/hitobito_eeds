= field_set_tag t('people.fields_eeds.scoutes_section') do
  = f.labeled_input_field :matricule_scout
  = f.labeled_collection_select :branche, Person.branche_labels.to_a, :first, :last, { include_blank: "" }, class: 'form-select form-select-sm'
  = f.labeled_input_field :unite
  = f.labeled_input_field :assurance_expiration, as: :date
  = f.labeled_text_area :progression_badges, rows: 3

= field_set_tag t('people.fields_eeds.parent_section') do
  = f.labeled_input_field :parent_contact_name
  = f.labeled_input_field :parent_contact_phone, as: :tel
  = f.labeled_input_field :parent_contact_email, as: :email

= field_set_tag t('people.fields_eeds.profile_section') do
  = f.labeled_input_field :profession
  = f.labeled_text_area :competences, rows: 3
